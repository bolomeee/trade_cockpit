  "features": [
    {
      "id": "F001",
      "name": "Watchlist 管理",
      "description": "用户可以管理自选股列表：搜索美股代码/名称添加股票，删除不再关注的股票，查看当前 watchlist",
      "user_story": "作为美股投资者，我想管理我关注的股票列表，这样我只看到我在意的标的",
      "priority": "P0",
      "status": "not_started",
      "phase": "design_needed",
      "dependencies": [],
      "estimated_sessions": 2,
      "estimated_files_changed": [],
      "scope": {
        "pages": ["首页 / Dashboard /"],
        "api_endpoints": [
          "GET /api/watchlist",
          "POST /api/watchlist",
          "DELETE /api/watchlist/:ticker",
          "GET /api/stocks/search?q="
        ],
        "db_tables": ["Stock"],
        "design_figma_link": ""
      },
      "contract": {
        "api_refs": ["API-CONTRACT.md#watchlist", "API-CONTRACT.md#stock-search"],
        "data_model_refs": ["DATA-MODEL.md#stock"],
        "acceptance_type": "functional"
      },
      "acceptance_criteria": [
        "用户可以在搜索框输入股票代码或名称，看到与美股同步的搜索结果",
        "搜索无结果时弹出 Alert 提示'未找到匹配的股票'",
        "用户可以从搜索结果中选择并添加股票到 watchlist",
        "添加后系统自动拉取该股票过去 250 个交易日的历史日线数据并计算 150MA 信号",
        "数据不足 150 个交易日的股票仍可添加，信号显示'数据不足'",
        "用户可以从 watchlist 中删除股票",
        "首页 Dashboard 显示所有已添加的股票及其当前信号状态",
        "首次使用 watchlist 为空时，首页显示引导提示'添加你的第一只股票'"
      ],
      "test_cases": {
        "unit": [],
        "integration": [],
        "e2e": []
      },
      "iteration_history": [],
      "notes": "",
      "completed_at": null
    },
    {
      "id": "F002",
      "name": "150MA 信号引擎",
      "description": "基于日线数据计算每只股票的 150 日均线信号：BUY_ZONE（斜率正+价距0–5%）、BREAKOUT（斜率正+向上穿越）、NEUTRAL（其余）。使用 20 日线性回归斜率判定均线方向，仅斜率为正时产生买入信号。自动识别历史回踩记录",
      "user_story": "作为美股投资者，我想让系统自动计算 150MA 信号，这样我不用手动逐只检查",
      "priority": "P0",
      "status": "not_started",
      "phase": "design_needed",
      "dependencies": [],
      "estimated_sessions": 2,
      "estimated_files_changed": [],
      "scope": {
        "pages": [],
        "api_endpoints": [
          "GET /api/signals",
          "GET /api/signals/:ticker"
        ],
        "db_tables": ["DailyBar", "Signal", "Pullback"],
        "design_figma_link": ""
      },
      "contract": {
        "api_refs": ["API-CONTRACT.md#signals"],
        "data_model_refs": ["DATA-MODEL.md#daily-bar", "DATA-MODEL.md#signal", "DATA-MODEL.md#pullback"],
        "acceptance_type": "functional"
      },
      "acceptance_criteria": [
        "系统正确计算 150 日简单移动平均线",
        "系统对最近 20 个交易日的 MA150 值做线性回归，斜率 > 0 判定为正、≤ 0 判定为负",
        "均线斜率为正且收盘价在 MA150 上方 0–5% 以内（含等于 MA）时，信号为 BUY_ZONE。价距% = (close - MA150) / MA150 × 100%",
        "均线斜率为正且收盘价从前一交易日低于 MA150 变为当日高于或等于 MA150 时，信号为 BREAKOUT",
        "同时满足 BUY_ZONE 和 BREAKOUT 条件时，取 BREAKOUT（穿越事件优先）",
        "不满足以上条件时信号为 NEUTRAL（包括斜率为负、价格远离 MA、价格在 MA 下方）",
        "当信号从非 BUY_ZONE 变为 BUY_ZONE 时记录为一次回踩事件，连续 BUY_ZONE 期间不重复记录",
        "回踩事件记录触及日期、价距、后续 10/20/30 日涨幅"
      ],
      "test_cases": {
        "unit": [],
        "integration": [],
        "e2e": []
      },
      "iteration_history": [],
      "notes": "信号判定优先级：BREAKOUT > BUY_ZONE > NEUTRAL",
      "completed_at": null
    },
    {
      "id": "F003",
      "name": "数据获取与调度",
      "description": "通过 Polygon.io API 拉取 EOD 日线数据，支持每日自动调度和用户手动触发刷新，遵守 5次/分钟的 rate limit",
      "user_story": "作为美股投资者，我想让数据每天自动更新，也能手动刷新，这样我总能看到最新信号",
      "priority": "P0",
      "status": "not_started",
      "phase": "design_needed",
      "dependencies": ["F001"],
      "estimated_sessions": 2,
      "estimated_files_changed": [],
      "scope": {
