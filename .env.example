# Project root .env — consumed by docker-compose.yml
# Copy to .env and fill real values. .env is gitignored.

FMP_API_KEY=
POLYGON_API_KEY=  # legacy (D034 rollback anchor)

# F105 Market Breakout Scanner cron schedule
SCANNER_CRON_HOUR=6                      # F105 每日市场扫描（错开 watchlist，避免 token bucket 竞争；D042）
SCANNER_CRON_MINUTE=15                   # 默认 06:15（watchlist refresh 耗时 <10s，留 15min 缓冲）
UNIVERSE_CRON_DAY=1                      # F105 候选池月级刷新：每月 1 号（D038）
UNIVERSE_CRON_HOUR=5                     # 05:00 早于 REFRESH/SCANNER，避免相互阻塞
UNIVERSE_CRON_MINUTE=0

# F211-d2 journal monthly review cron (defaults: 1st of month 06:00 UTC)
# JOURNAL_MONTHLY_CRON_DAY=1
# JOURNAL_MONTHLY_CRON_HOUR=6
# JOURNAL_MONTHLY_CRON_MINUTE=0

# v2.0 F208 AI Gateway (D064 / D069 / D075)
OPENAI_API_KEY=                          # LiteLLM 默认 api_key；所有未配置 override 的 task 使用此 key
AI_MODEL_DEFAULT=gpt-4o-mini             # default tier (F209 / F211 contradiction/news)
AI_MODEL_CRITICAL=gpt-4o                 # critical tier (F210)
AI_MODEL_COMPLEX=gpt-4o                  # complex tier (F211 journal_assistant)
AI_MONTHLY_BUDGET_USD=20.0               # 月度 AI 支出熔断阈值（USD），超出拒绝新请求
AI_MEMO_CACHE_TTL_HOURS=24               # memo dedup 命中窗口（小时）
AI_SCHEMA_VERSION=v1                     # schema 失效旗标；改版本号使历史缓存失效
# F211-a2 per-task model override (D075)
# AI_TASK_OVERRIDES_JSON='{}'            # JSON dict: task_type → {model, base_url?, api_key?, input_cost_per_1m?, output_cost_per_1m?}
# 示例：{"news_summarizer":{"model":"anthropic/claude-sonnet-4-6","base_url":"https://api.anthropic.com","api_key":"sk-ant-...","input_cost_per_1m":3.0,"output_cost_per_1m":15.0}}
