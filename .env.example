# Copy this file to .env before using services that need external credentials.
# Keep comments on their own lines: Docker Compose treats text after an empty
# assignment as part of that value.

FMP_API_KEY=
POLYGON_API_KEY=
OPENAI_API_KEY=
AI_TASK_OVERRIDES_JSON=

# Optional scheduler overrides (all values below have application defaults).
SCANNER_CRON_HOUR=6
SCANNER_CRON_MINUTE=15
UNIVERSE_CRON_WEEKDAY=mon
UNIVERSE_CRON_HOUR=5
UNIVERSE_CRON_MINUTE=0
EARNINGS_CRON_HOUR=5
EARNINGS_CRON_MINUTE=30
REGIME_CRON_HOUR=22
REGIME_CRON_MINUTE=15
SETUP_CRON_HOUR=22
SETUP_CRON_MINUTE=30
WEEKLY_STAGE_CRON_HOUR=22
WEEKLY_STAGE_CRON_MINUTE=20
JOURNAL_MONTHLY_CRON_DAY=1
JOURNAL_MONTHLY_CRON_HOUR=6
JOURNAL_MONTHLY_CRON_MINUTE=0

# Optional AI routing and budget overrides.
AI_MODEL_DEFAULT=gpt-5.4-nano
AI_MODEL_CRITICAL=gpt-5.4-mini
AI_MODEL_COMPLEX=gpt-5.4
AI_MONTHLY_BUDGET_USD=20.0
AI_MEMO_CACHE_TTL_HOURS=24
AI_SCHEMA_VERSION=v1
