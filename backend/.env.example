# MA150 Tracker Backend — Environment Variables
# Copy this file to .env and fill in real values. .env is gitignored.

# SQLite database URL (sync driver)
DATABASE_URL=sqlite:///./dev.db

# Polygon.io API key (required for F000-c and beyond; not used in F000-a)
POLYGON_API_KEY=

# Runtime environment: development | production
APP_ENV=development
